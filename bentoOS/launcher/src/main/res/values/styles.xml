<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- BentoOS Base Theme -->
    <style name="BentoOS.Theme" parent="android:Theme.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@color/bento_bg</item>
        <item name="android:colorBackground">@color/bento_bg</item>
        <item name="android:textColor">@color/bento_text_primary</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowAnimationStyle">@style/BentoOS.WindowAnimation</item>
    </style>

    <!-- Spring physics window animations -->
    <style name="BentoOS.WindowAnimation">
        <item name="android:windowEnterAnimation">@anim/window_open</item>
        <item name="android:windowExitAnimation">@anim/window_close</item>
    </style>

    <!-- Dock style -->
    <style name="BentoOS.Dock">
        <item name="android:background">@color/dock_bg</item>
        <item name="android:padding">16dp</item>
        <item name="android:elevation">8dp</item>
    </style>

    <!-- Menubar style -->
    <style name="BentoOS.Menubar">
        <item name="android:background">@color/menubar_bg</item>
        <item name="android:padding">8dp</item>
        <item name="android:elevation">4dp</item>
    </style>

    <!-- Window style -->
    <style name="BentoOS.Window">
        <item name="android:background">@color/bento_surface</item>
        <item name="android:elevation">16dp</item>
    </style>

</resources>