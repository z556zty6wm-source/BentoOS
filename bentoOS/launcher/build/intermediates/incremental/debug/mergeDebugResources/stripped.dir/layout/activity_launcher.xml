<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <!-- Bento grid wallpaper background -->
    <View
        android:id="@+id/wallpaper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0D0D0D"/>

    <!-- Status bar -->
    <LinearLayout
        android:id="@+id/status_bar"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#666666"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E8E8E8"
            android:textSize="13sp"
            android:fontFamily="monospace"/>

    </LinearLayout>

    <!-- Traffic lights -->
    <LinearLayout
        android:id="@+id/traffic_lights"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/status_bar"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/traffic_light_close"
            android:layout_marginEnd="6dp"/>

        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/traffic_light_minimize"
            android:layout_marginEnd="6dp"/>

        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/traffic_light_maximize"/>

    </LinearLayout>

    <!-- App grid -->
    <GridView
        android:id="@+id/app_grid"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/status_bar"
        android:layout_above="@id/dock_container"
        android:numColumns="auto_fit"
        android:columnWidth="120dp"
        android:horizontalSpacing="16dp"
        android:verticalSpacing="16dp"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:clipToPadding="false"
        android:stretchMode="columnWidth"
        android:overScrollMode="never"/>

    <!-- Dock -->
    <LinearLayout
        android:id="@+id/dock_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/dock"
            android:layout_width="wrap_content"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:background="@drawable/dock_background"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical"/>

    </LinearLayout>

</RelativeLayout>
