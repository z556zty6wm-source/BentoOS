<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC161616"
    android:padding="20dp"
    android:elevation="24dp">

    <!-- Toggle row 1 — WiFi, Bluetooth, Airplane -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:id="@+id/tile_wifi"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="#FF1e1e1e"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <TextView
                android:text="WiFi"
                android:textColor="#FFe0e0e0"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tile_bluetooth"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="#FF1e1e1e"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <TextView
                android:text="Bluetooth"
                android:textColor="#FFe0e0e0"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tile_airplane"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:background="#FF1e1e1e"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <TextView
                android:text="Airplane"
                android:textColor="#FFe0e0e0"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Brightness -->
    <TextView
        android:text="Brightness"
        android:textColor="#FF666666"
        android:textSize="12sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"/>
    <SeekBar
        android:id="@+id/slider_brightness"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:progressTint="#FF6c6cff"
        android:thumbTint="#FF6c6cff"/>

    <!-- Volume -->
    <TextView
        android:text="Volume"
        android:textColor="#FF666666"
        android:textSize="12sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"/>
    <SeekBar
        android:id="@+id/slider_volume"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:progressTint="#FF6c6cff"
        android:thumbTint="#FF6c6cff"/>

    <!-- Toggle row 2 — DND, Dark Mode, Gaming -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/tile_dnd"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="#FF1e1e1e"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <TextView
                android:text="Do Not Disturb"
                android:textColor="#FFe0e0e0"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tile_darkmode"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="#FF1e1e1e"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <TextView
                android:text="Dark Mode"
                android:textColor="#FFe0e0e0"
                android:textSize="11sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tile_gaming"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:background="#FF1e1e1e"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <TextView
                android:text="Gaming Mode"
                android:textColor="#FFe0e0e0"
                android:textSize="11sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>